# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/loud-cannabis
# Optional: defaults to MONGODB_URI if not set
STRAINS_MONGODB_URI=

# JWT Secrets (generate secure random strings for production)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client URLs (for CORS)
CUSTOMER_PORTAL_URL=http://localhost:3000
MANAGER_PORTAL_URL=http://localhost:3001

# Upload settings
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads

# Cloudflare R2 (optional, for signed media URLs)
R2_ACCOUNT_ID=
R2_BUCKET=
# API endpoint (account endpoint). Keep this as the R2 endpoint.
R2_ENDPOINT=
# Public endpoint (custom domain). Used for signed URLs.
R2_PUBLIC_ENDPOINT=
R2_SIGNED_URL_TTL=900

# Customer portal R2 credentials
R2_CUSTOMER_ACCESS_KEY_ID=
R2_CUSTOMER_SECRET_ACCESS_KEY=
R2_CUSTOMER_BUCKET=

# Manager portal R2 credentials
R2_MANAGER_ACCESS_KEY_ID=
R2_MANAGER_SECRET_ACCESS_KEY=
R2_MANAGER_BUCKET=

# Google AI Studio
GOOGLE_AI_STUDIO_API_KEY=your_api_key_here
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash
GOOGLE_AI_STUDIO_CACHE_TTL_MS=3600000
